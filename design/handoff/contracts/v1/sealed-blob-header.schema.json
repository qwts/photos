{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "properties": {
    "magic": {
      "type": "string",
      "const": "OVERLOOK-IMAGE-TRAIL-SEALED-BLOB"
    },
    "schemaVersion": {
      "type": "number",
      "const": 1
    },
    "pairingId": {
      "type": "string",
      "format": "uuid",
      "pattern": "^([0-9a-fA-F]{8}-[0-9a-fA-F]{4}-[1-8][0-9a-fA-F]{3}-[89abAB][0-9a-fA-F]{3}-[0-9a-fA-F]{12}|00000000-0000-0000-0000-000000000000|ffffffff-ffff-ffff-ffff-ffffffffffff)$"
    },
    "keyId": {
      "type": "string",
      "pattern": "^interop:[0-9a-f]{8}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{12}$"
    },
    "cipher": {
      "type": "object",
      "properties": {
        "name": {
          "type": "string",
          "const": "AES-GCM"
        },
        "iv": {
          "type": "string",
          "pattern": "^[A-Za-z0-9+/]{16}$"
        }
      },
      "required": [
        "name",
        "iv"
      ],
      "additionalProperties": false
    }
  },
  "required": [
    "magic",
    "schemaVersion",
    "pairingId",
    "keyId",
    "cipher"
  ],
  "additionalProperties": false,
  "$id": "https://github.com/qwts/photos/blob/main/design/handoff/contracts/v1/sealed-blob-header.schema.json",
  "title": "Overlook and Image Trail AES-GCM sealed blob header v1",
  "$comment": "The exact UTF-8 JSON header bytes are authenticated as AES-GCM AAD. Descriptive original metadata remains encrypted."
}
