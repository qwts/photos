{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "properties": {
    "magic": {
      "type": "string",
      "const": "OVERLOOK-IMAGE-TRAIL-PAIRING"
    },
    "formatVersion": {
      "type": "number",
      "const": 1
    },
    "pairingId": {
      "type": "string",
      "format": "uuid",
      "pattern": "^([0-9a-fA-F]{8}-[0-9a-fA-F]{4}-[1-8][0-9a-fA-F]{3}-[89abAB][0-9a-fA-F]{3}-[0-9a-fA-F]{12}|00000000-0000-0000-0000-000000000000|ffffffff-ffff-ffff-ffff-ffffffffffff)$"
    },
    "keyId": {
      "type": "string",
      "pattern": "^interop:[0-9a-f]{8}-[0-9a-f]{4}-[1-8][0-9a-f]{3}-[89ab][0-9a-f]{3}-[0-9a-f]{12}$"
    },
    "createdAt": {
      "type": "string",
      "format": "date-time",
      "pattern": "^(?:(?:\\d\\d[2468][048]|\\d\\d[13579][26]|\\d\\d0[48]|[02468][048]00|[13579][26]00)-02-29|\\d{4}-(?:(?:0[13578]|1[02])-(?:0[1-9]|[12]\\d|3[01])|(?:0[469]|11)-(?:0[1-9]|[12]\\d|30)|(?:02)-(?:0[1-9]|1\\d|2[0-8])))T(?:(?:[01]\\d|2[0-3]):[0-5]\\d(?::[0-5]\\d(?:\\.\\d+)?)?(?:Z))$"
    },
    "kdf": {
      "type": "object",
      "properties": {
        "name": {
          "type": "string",
          "const": "PBKDF2"
        },
        "hash": {
          "type": "string",
          "const": "SHA-256"
        },
        "iterations": {
          "type": "number",
          "const": 600000
        },
        "salt": {
          "$ref": "#/$defs/__schema0"
        }
      },
      "required": [
        "name",
        "hash",
        "iterations",
        "salt"
      ],
      "additionalProperties": false
    },
    "cipher": {
      "type": "object",
      "properties": {
        "name": {
          "type": "string",
          "const": "AES-256-GCM"
        },
        "iv": {
          "$ref": "#/$defs/__schema0"
        },
        "ciphertext": {
          "$ref": "#/$defs/__schema0"
        }
      },
      "required": [
        "name",
        "iv",
        "ciphertext"
      ],
      "additionalProperties": false
    }
  },
  "required": [
    "magic",
    "formatVersion",
    "pairingId",
    "keyId",
    "createdAt",
    "kdf",
    "cipher"
  ],
  "additionalProperties": false,
  "$defs": {
    "__schema0": {
      "type": "string",
      "minLength": 1,
      "pattern": "^(?:[A-Za-z0-9+/]{4})*(?:[A-Za-z0-9+/]{2}==|[A-Za-z0-9+/]{3}=)?$"
    }
  },
  "$id": "https://github.com/qwts/photos/blob/main/design/handoff/contracts/v1/pairing-bundle.schema.json",
  "title": "Overlook and Image Trail password-protected pairing bundle v1",
  "$comment": "Opening the bundle additionally authenticates all header fields as AES-GCM AAD and verifies that the encrypted payload identity matches the header."
}
