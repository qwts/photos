{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "properties": {
    "schemaVersion": {
      "type": "number",
      "const": 1
    },
    "transferId": {
      "$ref": "#/$defs/__schema0"
    },
    "recordInteropId": {
      "$ref": "#/$defs/__schema0"
    },
    "role": {
      "type": "string",
      "const": "original"
    },
    "blobId": {
      "type": "string",
      "minLength": 1
    },
    "mimeType": {
      "type": "string",
      "minLength": 1
    },
    "byteLength": {
      "type": "integer",
      "minimum": 0,
      "maximum": 9007199254740991
    },
    "contentHash": {
      "type": "string",
      "pattern": "^[a-f0-9]{64}$"
    }
  },
  "required": [
    "schemaVersion",
    "transferId",
    "recordInteropId",
    "role",
    "blobId",
    "mimeType",
    "byteLength",
    "contentHash"
  ],
  "additionalProperties": false,
  "$defs": {
    "__schema0": {
      "type": "string",
      "format": "uuid",
      "pattern": "^([0-9a-fA-F]{8}-[0-9a-fA-F]{4}-[1-8][0-9a-fA-F]{3}-[89abAB][0-9a-fA-F]{3}-[0-9a-fA-F]{12}|00000000-0000-0000-0000-000000000000|ffffffff-ffff-ffff-ffff-ffffffffffff)$"
    }
  },
  "$id": "https://github.com/qwts/photos/blob/main/design/handoff/contracts/v1/sealed-blob-descriptor.schema.json",
  "title": "Overlook and Image Trail encrypted original descriptor v1",
  "$comment": "The descriptor is inside the authenticated ciphertext and is followed by the exact original bytes."
}
