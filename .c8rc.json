{
  "all": true,
  "include": ["src/main/**", "src/shared/**", "src/renderer/src/components/Icon.tsx", "src/renderer/src/components/Switch.tsx"],
  "exclude": [
    "tests/**",
    "**/*.test.ts",
    "src/main/index.ts",
    "src/main/ipc.ts",
    "src/main/app-bootstrap.ts",
    "src/main/backup/provider-runtime-factory.ts",
    "src/main/backup/restore-runtime-factory.ts",
    "src/main/export/export-facade-factory.ts",
    "src/main/export/export-destination.ts",
    "src/main/library/library-picker.ts",
    "src/main/i18n/locale-resolver.ts",
    "src/preload/**",
    "src/shared/**/types.ts"
  ],
  "excludeAfterRemap": true,
  "reporter": ["text", "lcov", "json-summary"],
  "reports-dir": "coverage",
  "check-coverage": true,
  "lines": 90,
  "branches": 80
}
