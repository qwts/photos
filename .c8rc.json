{
  "all": true,
  "include": ["src/**"],
  "exclude": ["tests/**", "**/*.test.ts", "src/main/**", "src/preload/**", "src/renderer/**"],
  "excludeAfterRemap": true,
  "reporter": ["text", "lcov", "json-summary"],
  "reports-dir": "coverage",
  "check-coverage": true,
  "lines": 90,
  "branches": 80
}
