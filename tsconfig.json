{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "lib": ["ES2022"],
    "strict": true,
    "exactOptionalPropertyTypes": true,
    "noUncheckedIndexedAccess": true,
    "noImplicitOverride": true,
    "noFallthroughCasesInSwitch": true,
    "noPropertyAccessFromIndexSignature": true,
    "noEmitOnError": true,
    "types": ["node"],
    "skipLibCheck": true
  },
  "include": ["src/shared/**/*.ts", "tests/**/*.ts", "playwright.config.ts", "playwright.perf.config.ts", "electron.vite.config.ts"],
  "exclude": ["tests/dom", "tests/fixtures"]
}
