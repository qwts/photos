{
  "name": "photos",
  "version": "0.1.0",
  "description": "A photo library app.",
  "private": true,
  "type": "module",
  "scripts": {
    "format": "prettier --write \"**/*.{ts,json,md,css,yml,yaml}\" \".prettierrc.json\"",
    "format:check": "prettier --check \"**/*.{ts,json,md,css,yml,yaml}\" \".prettierrc.json\"",
    "lint": "npm run lint:package && npm run lint:new-files && eslint . && npm run lint:cycles && npm run lint:dead && npm run lint:types",
    "lint:package": "node scripts/check-package-pins.mjs",
    "lint:new-files": "node scripts/check-new-file-size.mjs",
    "lint:cycles": "madge --circular --extensions ts src",
    "lint:dead": "knip",
    "lint:types": "type-coverage --at-least 99.8 --strict",
    "typecheck": "tsc --noEmit",
    "test:compile": "rm -rf .test-dist && tsc -p tsconfig.test.json",
    "test:unit:run": "node --test '.test-dist/tests/**/*.test.js'",
    "test": "npm run typecheck && npm run test:compile && npm run test:unit:run",
    "test:cov": "npm run typecheck && npm run test:compile && c8 npm run test:unit:run",
    "coverage:summary": "node scripts/report-coverage-summary.mjs"
  },
  "devDependencies": {
    "@eslint/js": "10.0.1",
    "@types/node": "24.13.3",
    "c8": "11.0.0",
    "eslint": "10.7.0",
    "knip": "6.26.0",
    "madge": "8.0.0",
    "prettier": "3.9.5",
    "type-coverage": "2.29.7",
    "typescript": "6.0.3",
    "typescript-eslint": "8.63.0"
  },
  "overrides": {
    "madge": {
      "typescript": "$typescript"
    }
  }
}
