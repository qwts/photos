{
  "name": "photos",
  "version": "0.1.0",
  "description": "A photo library app.",
  "private": true,
  "type": "module",
  "main": "./out/main/index.js",
  "scripts": {
    "prepare": "husky",
    "changeset": "changeset",
    "changeset:version": "changeset version",
    "format": "prettier --write \"**/*.{ts,tsx,json,md,css,yml,yaml,html}\" \".prettierrc.json\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,json,md,css,yml,yaml,html}\" \".prettierrc.json\"",
    "lint": "npm run lint:package && npm run lint:new-files && eslint . && npm run lint:cycles && npm run lint:dead && npm run lint:types",
    "lint:package": "node scripts/check-package-pins.mjs",
    "lint:new-files": "node scripts/check-new-file-size.mjs",
    "lint:cycles": "madge --circular --extensions ts,tsx src",
    "lint:dead": "knip",
    "lint:types": "type-coverage --at-least 99.8 --strict && type-coverage -p src/main --at-least 99.8 --strict && type-coverage -p src/preload --at-least 99.8 --strict && type-coverage -p src/renderer --at-least 99.8 --strict",
    "typecheck": "tsc --noEmit && tsc --noEmit -p src/main && tsc --noEmit -p src/preload && tsc --noEmit -p src/renderer",
    "clean": "rm -rf dist out",
    "dev": "electron-vite dev",
    "build": "npm run clean && electron-vite build",
    "package": "npm run build && electron-builder --publish never",
    "ci": "npm run lint && npm run format:check && npm run test:cov && npm run build",
    "test:compile": "rm -rf .test-dist && tsc -p tsconfig.test.json",
    "test:unit:run": "node --test '.test-dist/tests/**/*.test.js'",
    "test": "npm run typecheck && npm run test:compile && npm run test:unit:run",
    "test:cov": "npm run typecheck && npm run test:compile && c8 npm run test:unit:run",
    "coverage:summary": "node scripts/report-coverage-summary.mjs",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:headed": "playwright test --headed"
  },
  "devDependencies": {
    "@changesets/cli": "2.31.0",
    "@eslint-react/eslint-plugin": "5.14.5",
    "@eslint/js": "10.0.1",
    "@playwright/test": "1.61.1",
    "@types/node": "24.13.3",
    "@types/react": "18.3.31",
    "@types/react-dom": "18.3.7",
    "@vitejs/plugin-react": "5.2.0",
    "c8": "11.0.0",
    "electron": "43.1.0",
    "electron-builder": "26.15.3",
    "electron-vite": "5.0.0",
    "eslint": "10.7.0",
    "eslint-plugin-react-hooks": "7.1.1",
    "husky": "9.1.7",
    "knip": "6.26.0",
    "lint-staged": "17.0.8",
    "lucide-react": "1.24.0",
    "madge": "8.0.0",
    "node-test-github-reporter": "1.3.2",
    "prettier": "3.9.5",
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "type-coverage": "2.29.7",
    "typescript": "6.0.3",
    "typescript-eslint": "8.63.0",
    "vite": "7.3.6",
    "zod": "4.4.3"
  },
  "overrides": {
    "madge": {
      "typescript": "$typescript"
    },
    "type-coverage": {
      "typescript": "$typescript"
    }
  },
  "lint-staged": {
    "*.{ts,tsx,mjs}": [
      "eslint --fix --no-warn-ignored",
      "prettier --write"
    ],
    "*.{json,md,css,yml,yaml,html}": [
      "prettier --write"
    ]
  },
  "allowScripts": {
    "electron@43.1.0": true,
    "esbuild@0.25.12": true,
    "esbuild@0.28.1": true
  }
}
