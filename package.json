{
  "name": "photos",
  "version": "0.12.2",
  "description": "A photo library app.",
  "private": true,
  "type": "module",
  "main": "./out/main/index.js",
  "scripts": {
    "prepare": "husky",
    "changeset": "changeset",
    "changeset:version": "changeset version",
    "format": "prettier --write \"**/*.{ts,tsx,json,md,css,yml,yaml,html}\" \".prettierrc.json\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,json,md,css,yml,yaml,html}\" \".prettierrc.json\"",
    "lint": "npm run lint:package && npm run lint:new-files && eslint . && npm run lint:cycles && npm run lint:dead && npm run lint:types",
    "lint:package": "node scripts/check-package-pins.mjs",
    "lint:new-files": "node scripts/check-new-file-size.mjs",
    "lint:cycles": "madge --circular --extensions ts,tsx src",
    "lint:dead": "knip",
    "lint:types": "type-coverage --at-least 99.8 --strict && type-coverage -p src/main --at-least 99.8 --strict && type-coverage -p src/preload --at-least 99.8 --strict && type-coverage -p src/renderer --at-least 99.8 --strict",
    "typecheck": "tsc --noEmit && tsc --noEmit -p src/main && tsc --noEmit -p src/preload && tsc --noEmit -p src/renderer && tsc --noEmit -p .storybook",
    "clean": "rm -rf dist out",
    "dev": "electron-vite dev",
    "build": "npm run clean && electron-vite build",
    "package": "npm run build && electron-builder --publish never -c.mac.identity=null",
    "package:signed": "npm run build && electron-builder --publish never",
    "ci": "npm run lint && npm run format:check && npm run check:acceptance-coverage && npm run test:cov && npm run build",
    "test:compile": "rm -rf .test-dist && tsc -p tsconfig.test.json",
    "test:unit:run": "ELECTRON_RUN_AS_NODE=1 electron --test '.test-dist/tests/**/*.test.js'",
    "test": "npm run typecheck && npm run test:compile && npm run test:unit:run",
    "test:cov": "npm run typecheck && npm run test:compile && c8 npm run test:unit:run",
    "coverage:summary": "node scripts/report-coverage-summary.mjs",
    "check:acceptance-coverage": "node scripts/check-e2e-coverage-map.mjs && node scripts/check-acceptance-coverage-diff.mjs",
    "test:pcloud:live": "npm run test:compile && OVERLOOK_PCLOUD_LIVE=1 ELECTRON_RUN_AS_NODE=1 electron --test '.test-dist/tests/backup/pcloud-live-contract.test.js'",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:headed": "playwright test --headed",
    "test:perf": "playwright test --config playwright.perf.config.ts",
    "storybook": "storybook dev -p 6006",
    "build:storybook": "storybook build",
    "test:stories": "test-storybook",
    "test:stories:ci": "npm run build:storybook && concurrently -k -s first -n sb,test \"http-server storybook-static --host 127.0.0.1 --port 6006 --silent\" \"wait-on tcp:127.0.0.1:6006 && test-storybook --url http://127.0.0.1:6006\"",
    "seed:dev": "OVERLOOK_SEED=96 electron-vite dev",
    "seed:perf": "OVERLOOK_SEED_SYNTHETIC=200000 electron-vite dev",
    "postinstall": "node scripts/ensure-electron-binary.mjs && electron-builder install-app-deps"
  },
  "devDependencies": {
    "@changesets/cli": "2.31.0",
    "@eslint-react/eslint-plugin": "5.14.5",
    "@eslint/js": "10.0.1",
    "@playwright/test": "1.61.1",
    "@storybook/react-vite": "10.5.0",
    "@storybook/test-runner": "0.24.4",
    "@types/node": "24.13.3",
    "@types/react": "18.3.31",
    "@types/react-dom": "18.3.7",
    "@vitejs/plugin-react": "5.2.0",
    "c8": "11.0.0",
    "concurrently": "10.0.3",
    "electron": "42.6.1",
    "electron-builder": "26.15.3",
    "electron-vite": "5.0.0",
    "eslint": "10.7.0",
    "eslint-plugin-react-hooks": "7.1.1",
    "http-server": "14.1.1",
    "husky": "9.1.7",
    "knip": "6.26.0",
    "lint-staged": "17.0.8",
    "lucide-react": "1.24.0",
    "madge": "8.0.0",
    "node-test-github-reporter": "1.3.2",
    "prettier": "3.9.5",
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "storybook": "10.5.0",
    "type-coverage": "2.29.7",
    "typescript": "6.0.3",
    "typescript-eslint": "8.63.0",
    "vite": "7.3.6",
    "wait-on": "9.0.10",
    "zod": "4.4.3"
  },
  "overrides": {
    "madge": {
      "typescript": "$typescript"
    },
    "type-coverage": {
      "typescript": "$typescript"
    }
  },
  "lint-staged": {
    "*.{ts,tsx,mjs}": [
      "eslint --fix --no-warn-ignored",
      "prettier --write"
    ],
    "*.{json,md,css,yml,yaml,html}": [
      "prettier --write"
    ]
  },
  "allowScripts": {
    "esbuild@0.25.12": true,
    "esbuild@0.28.1": true,
    "better-sqlite3-multiple-ciphers@12.11.1": true,
    "electron@42.6.1": true
  },
  "dependencies": {
    "better-sqlite3-multiple-ciphers": "12.11.1",
    "exifr": "7.1.3",
    "sharp": "0.35.3"
  }
}
