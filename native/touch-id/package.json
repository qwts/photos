{
  "name": "@overlook/touch-id",
  "version": "0.1.0",
  "private": true,
  "description": "Overlook's signed macOS Touch ID and Data Protection Keychain bridge",
  "main": "index.cjs",
  "gypfile": true,
  "files": [
    "index.cjs",
    "prebuilds/**/*.node"
  ],
  "binary": {
    "napi_versions": [
      8
    ]
  },
  "os": [
    "darwin"
  ],
  "cpu": [
    "arm64",
    "x64"
  ],
  "scripts": {
    "install": "node-gyp rebuild && node prepare-prebuild.cjs"
  },
  "dependencies": {
    "node-addon-api": "8.9.0"
  },
  "devDependencies": {
    "node-gyp": "13.0.1",
    "prebuildify": "6.0.1"
  }
}
