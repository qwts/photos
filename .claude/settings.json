{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "permissions": {
    "allow": ["Bash(gh pr ready *)"]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "node \"$CLAUDE_PROJECT_DIR\"/scripts/guard-agent-command.mjs --protocol=claude"
          }
        ]
      }
    ]
  }
}
